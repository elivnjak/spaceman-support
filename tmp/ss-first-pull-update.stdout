          "Partially obstructed or tight clearance",
          "Blocked or no clearance"
        ]
      }
    },
    {
      "id": "ev_viscosity_setting",
      "type": "reading",
      "actionId": "read_viscosity_setting",
      "required": false,
      "description": "Viscosity setting reported.",
      "valueDefinition": {
        "kind": "number",
        "unit": "setting",
        "notes": "min=0, max=100"
      }
    }
  ],
