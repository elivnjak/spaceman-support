{
  "id": "85ffe006-7aa7-44a1-ab7f-e01960f01ca7",
  "labelId": "ss_first_pull_runny_after_idle",
  "title": "First dispense runny after idle (hot-gas release / idle effects)",
  "enabled": true,
  "steps": [
    {
      "check": "Pattern confirmed (first runny, second better).",
      "title": "Confirm pattern",
      "step_id": "877f00b9-b0fe-437c-b32f-586cc89ff380",
      "instruction": "Take photo/video of first pull and second pull after waiting ~30 seconds."
    },
    {
      "check": "Served product holds shape.",
      "title": "Refresh small amount after idle",
      "step_id": "a71176ab-bf84-43b8-9f0b-6ba9ef761b87",
      "instruction": "After long idle, pull a small amount to refresh product, wait ~30 seconds, then serve."
    },
    {
      "check": "Support confirms recommended setting for your model.",
      "title": "Do not change advanced settings blindly",
      "step_id": "a255b86a-2a86-4a7f-8947-e12bd5e4fb68",
      "instruction": "If hot-gas release is suspected, escalate to support/technician for guidance (settings are passcode protected)."
    },
    {
      "check": "Reduces baseline runny behaviour.",
      "title": "Check environment basics",
      "step_id": "6f0a40d6-8ff9-4ff8-b6e7-6f2e56546c91",
      "instruction": "Ensure clearance, avoid direct sun/heat sources, and confirm mix is cold."
    }
  ],
  "schemaVersion": 2,
  "symptoms": [
    {
      "id": "sym_first_pull_runny",
      "description": "First pull after idle is runny; subsequent pulls improve."
    },
    {
      "id": "sym_idle_related",
      "description": "Issue correlates with long idle periods (overnight/slow times)."
    },
    {
      "id": "sym_display_seems_ok",
      "description": "Display temperatures/settings appear normal."
    },
    {
      "id": "sym_only_first",
      "description": "Only affects first 1–2 serves after idle."
    }
  ],
  "evidenceChecklist": [
    {
      "id": "ev_product_photo",
      "type": "photo",
      "actionId": "take_photo_product",
      "required": true,
      "description": "Photo/video of first pull and second pull.",
      "valueDefinition": {
        "kind": "photo"
      }
    },
    {
      "id": "ev_idle_time",
      "type": "confirmation",
      "actionId": "confirm_idle_time",
      "required": true,
      "description": "Idle time >30 minutes confirmed.",
      "valueDefinition": {
        "kind": "boolean"
      }
    },
    {
      "id": "ev_hot_gas_setting_known",
      "type": "confirmation",
      "required": false,
      "description": "Hot-gas release settings known/changed recently (if you have access).",
