DATABASE_URL=postgres://rag:rag@localhost:5432/rag
OPENAI_API_KEY=
# Optional: dedicated secret for public chat session access tokens.
# If omitted, TURNSTILE_SECRET_KEY is used as fallback.
CHAT_SESSION_TOKEN_SECRET=
# Cloudflare Turnstile bot protection (free): used to verify first chat message.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# In development, Turnstile is skipped by default to avoid browser console noise.
# Set both flags to true if you need to test Turnstile locally.
# TURNSTILE_ENFORCE=false
# NEXT_PUBLIC_TURNSTILE_ENFORCE=false
# Image embeddings: use one of the following.
# Option A — Replicate (recommended): get token at https://replicate.com/account/api
HUGGINGFACE_API_KEY=
REPLICATE_API_TOKEN=
# Rate limiting backend:
# - memory (default): no extra cost, good for low traffic/single instance
# - redis: distributed rate limits for multi-instance production
# RATE_LIMIT_PROVIDER=memory
# Optional when RATE_LIMIT_PROVIDER=redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Option B — HuggingFace: if the serverless API returns 410, deploy openai/clip-vit-base-patch32
# via Inference Endpoints and set your endpoint URL here:
# HUGGINGFACE_CLIP_URL=https://your-endpoint-id.region.inference.huggingface.co

# Admin credentials used by db:seed
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Escalation webhook URL (POST with JSON handoff payload on escalation)
ESCALATION_WEBHOOK_URL=
# Telegram escalation notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Email fallback when Telegram delivery fails (optional)
# Recommended provider: Resend (free tier). Use onboarding@resend.dev for initial testing.
RESEND_API_KEY=
# Public app URL used in emails and external links (optional but recommended in production)
# NEXT_PUBLIC_BASE_URL=https://your-app.example.com
ESCALATION_EMAIL_TO=
ESCALATION_EMAIL_FROM=
ESCALATION_EMAIL_REPLY_TO=
# Optional auth/user email sender overrides (falls back to escalation sender vars when omitted)
# AUTH_EMAIL_FROM=
# AUTH_EMAIL_REPLY_TO=

# Error logs path (optional).
# If not set: uses STORAGE_PATH/logs (when STORAGE_PATH is set), then
# RAILWAY_VOLUME_MOUNT_PATH/logs (when set), then ./logs
# ERROR_LOGS_PATH=
# Audit logs retention in days (optional).
# Default is disabled (no auto-delete) so Insights/Dashboard can use full history.
# Set to a positive number to enable cleanup.
# AUDIT_LOG_RETENTION_DAYS=0

# --- For npm run railway:setup:prod (run migrations from your Mac) ---
# Option A: Set DATABASE_URL to the **Postgres** public URL (not the app URL).
# In Railway: Postgres service → Variables or Connect → copy "Public URL" or "DATABASE_PUBLIC_URL".
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE (host like monorail.proxy.rlwy.net or *.railway.app).
# Option B: Or set POSTGRES_HOST (public host), POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB, POSTGRES_PORT.
# POSTGRES_HOST=
# POSTGRES_PORT=5432
# POSTGRES_USER=rag
# POSTGRES_PASSWORD=
# POSTGRES_DB=railway

# --- For npm run backup:prod / restore:prod ---
# Use a Railway token. Account tokens can create/restore storage snapshots.
# Project tokens can still read variables and handle DB dump/restore, but may be
# rejected by Railway for storage snapshot mutations.
# RAILWAY_TOKEN=
# Optional overrides if the Railway resource IDs ever change:
# RAILWAY_PROJECT_ID=
# RAILWAY_ENVIRONMENT_ID=
# RAILWAY_APP_SERVICE_ID=
# RAILWAY_POSTGRES_SERVICE_ID=
