{
  "name": "ai-rag-saas",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:init": "npx tsx scripts/init-vector-extension.ts",
    "db:deploy": "npx tsx scripts/init-vector-extension.ts && npm run db:migrate",
    "db:setup": "npx tsx scripts/init-vector-extension.ts && npm run db:migrate && npm run db:seed",
    "railway:link": "npx @railway/cli@latest link",
    "railway:setup": "npx @railway/cli@latest run npm run db:setup",
    "railway:setup:prod": "npx tsx scripts/run-with-production-env.ts npm run db:setup",
    "railway:migrate": "npm run db:deploy",
    "railway:start": "npm run railway:migrate && npm start",
    "railway:prod": "npx tsx scripts/run-with-production-env.ts",
    "eval": "npx tsx scripts/eval.ts",
    "playbook:test": "node --import tsx scripts/playbook-test.ts",
    "db:seed": "npx tsx scripts/setup-db.ts",
    "types:audit": "npx tsx scripts/audit-input-types.ts",
    "types:normalize:dry": "npx tsx scripts/normalize-input-types.ts --mode dry-run",
    "types:normalize": "npx tsx scripts/normalize-input-types.ts --mode apply",
    "test:playbook-harness": "node --import tsx --test scripts/playbook-test/**/*.test.ts"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.0",
    "exceljs": "^4.4.0",
    "jsdom": "^28.1.0",
    "next": "^16.1.6",
    "openai": "^4.0.0",
    "pdfjs-dist": "^5.4.624",
    "playwright": "^1.58.2",
    "postgres": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0",
    "sharp": "^0.33.0",
    "turndown": "^7.2.2",
    "zod": "^3.25.76"
  },
  "overrides": {
    "punycode": "^2.3.1",
    "tar": "^7.5.8",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    }
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/turndown": "^5.0.6",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
